# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# OLLAMA SETTINGS
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# DATABASE SETTINGS
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_lab

# LAB CONFIG
# Options: openai | ollama
DEFAULT_PROVIDER=openai
LOG_LEVEL=INFO
